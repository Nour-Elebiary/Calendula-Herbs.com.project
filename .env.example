# ============================================================
# CALENDULA HERBS — Environment Variables Template
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to git
# ============================================================

# ── App ─────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=REPLACE_ME_generate_with_openssl_rand_base64_32

# ── Database (Supabase) ──────────────────────────────────────
# Find in: Supabase → Project → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Cloudinary ──────────────────────────────────────────────
# Find in: Cloudinary → Dashboard
CLOUDINARY_CLOUD_NAME=REPLACE_ME
CLOUDINARY_API_KEY=REPLACE_ME
CLOUDINARY_API_SECRET=REPLACE_ME
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=REPLACE_ME

# ── Resend (Transactional Email) ─────────────────────────────
# Find in: Resend → API Keys
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Upstash Redis (Rate Limiting) ────────────────────────────
# Find in: Upstash → Redis → REST API
UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME

# ── Admin Bootstrap (seeding only) ───────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_INITIAL_KEY=see_secrets.json

# ── Africa's Talking (SMS OTP - optional) ────────────────────
AT_API_KEY=REPLACE_ME_optional
AT_USERNAME=REPLACE_ME_optional

# ── Public Variables (safe to expose) ────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_COMPANY_NAME=Calendula Herbs For Import & Export
NEXT_PUBLIC_COMPANY_LINKEDIN=https://eg.linkedin.com/company/calendula-herbs-import-export
